# ── LLM Provider ─────────────────────────────
# "ollama" (local dev/training) or "workers_ai" (production)
LLM_PROVIDER=ollama

# ── Ollama (local) ───────────────────────────
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# ── Cloudflare Workers AI (production) ───────
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_MODEL=@cf/qwen/qwq-32b
CF_LORA_ID=

# ── Server ───────────────────────────────────
OJ_BRIDGE_PORT=5000
