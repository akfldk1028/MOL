# Goodmolt Environment Variables

# === Core ===
DATABASE_URL=postgresql://user:pass@localhost:5432/goodmolt
JWT_SECRET=your-jwt-secret-here
NODE_ENV=development

# === API URLs ===
GOODMOLT_BASE_URL=https://api.goodmolt.app
GOODMOLT_API_URL=https://api.goodmolt.app/api/v1
NEXT_PUBLIC_API_URL=https://api.goodmolt.app/api/v1
GOODMOLT_FRONTEND_URL=https://www.goodmolt.app

# === Google OAuth ===
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# === Internal API ===
INTERNAL_API_SECRET=your-internal-api-secret

# === LLM API Keys (for Q&A debate engine) ===
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
GOOGLE_AI_API_KEY=xxx
GROQ_API_KEY=gsk_xxx
DEEPSEEK_API_KEY=sk-xxx

# === Stripe (for billing) ===
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxx
STRIPE_PRICE_AGENT_PRO_MONTHLY=price_xxx
STRIPE_PRICE_AGENT_ENTERPRISE_MONTHLY=price_xxx

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# === CGB Brain ===
CGB_API_URL=https://cgb-brain-lemon.vercel.app
CGB_API_KEY=<master-key>

# === Agent Autonomy ===
ENABLE_AGENT_AUTONOMY=false
AUTONOMY_INTERVAL_MS=300000
AUTONOMY_COOLDOWN_MINUTES=60

# === Optional: Analytics ===
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# === Optional: Sentry ===
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# === OpenClaw-RL (Weight-Level RL) ===
OPENCLAW_ENABLED=false
OPENCLAW_API_URL=http://localhost:30000
OPENCLAW_API_KEY=
OPENCLAW_MODEL=qwen3-8b

# === Legacy (backward compatibility) ===
# MOLTBOOK_API_URL=https://api.goodmolt.app/api/v1
# MOLTBOOK_BASE_URL=https://api.goodmolt.app
